{
  "_comment": "ZeroTrustAuditor configuration file. Copy and customize per engagement.",
  "_version": "1.0.0",

  "audit": {
    "staleAccountThresholdDays": 90,
    "staleComputerThresholdDays": 60,
    "maxHostsPerRun": 500,
    "parallelModuleTimeout": 300,
    "skipModules": [],
    "excludeHosts": [],
    "excludeChecks": []
  },

  "thresholds": {
    "localAdminOverlapMinHosts": 2,
    "localAdminOverlapCriticalHosts": 5,
    "rdpGroupMemberWarningCount": 3,
    "securityLogMinSizeBytes": 1073741824,
    "smbShareBroadPrincipals": [
      "Everyone",
      "BUILTIN\\Everyone",
      "NT AUTHORITY\\Authenticated Users",
      "Authenticated Users",
      "BUILTIN\\Users",
      "Domain Users"
    ],
    "privilegedGroups": [
      "Domain Admins",
      "Enterprise Admins",
      "Schema Admins",
      "Administrators",
      "Account Operators",
      "Backup Operators",
      "Print Operators",
      "Server Operators"
    ],
    "expectedDCSyncPrincipals": [
      "Domain Controllers",
      "Enterprise Domain Controllers",
      "Administrators"
    ],
    "adminShareAllowedPrincipals": [
      "Administrators",
      "BUILTIN\\Administrators",
      "Domain Admins",
      "SYSTEM",
      "NT AUTHORITY\\SYSTEM"
    ],
    "lmCompatibilityLevelMinimum": 3,
    "ntlmSafeMinimum": 5
  },

  "correlation": {
    "enabled": true,
    "rules": [
      {
        "name": "SMB relay + local admin spread",
        "checkA": "SMB_SIGNING_DISABLED",
        "checkB": "LOCAL_ADMIN_OVERLAP",
        "riskBoost": 2.0,
        "rationale": "Unsigned SMB enables NTLM relay; shared local admin means one relay = many hosts compromised."
      },
      {
        "name": "NTLMv1 + local admin spread",
        "checkA": "NTLM_V1_ENABLED",
        "checkB": "LOCAL_ADMIN_OVERLAP",
        "riskBoost": 2.0,
        "rationale": "NTLMv1 hashes crack quickly; combined with admin overlap enables mass lateral movement."
      },
      {
        "name": "Unconstrained delegation + Kerberoasting",
        "checkA": "UNCONSTRAINED_DELEGATION",
        "checkB": "KERBEROASTABLE_SPN",
        "riskBoost": 2.0,
        "rationale": "Cracking the Kerberoastable SPN yields a ticket that can be presented to the unconstrained host."
      },
      {
        "name": "DCSync rights + stale account",
        "checkA": "DCSYNC_ACE",
        "checkB": "STALE_PRIVILEGED_ACCOUNT",
        "riskBoost": 2.0,
        "rationale": "Stale accounts are unlikely to have MFA or active monitoring; DCSync right means instant domain takeover."
      },
      {
        "name": "Unencrypted WinRM + local admin spread",
        "checkA": "WINRM_UNENCRYPTED",
        "checkB": "LOCAL_ADMIN_OVERLAP",
        "riskBoost": 2.0,
        "rationale": "Plaintext WinRM exposes credentials in transit; admin overlap multiplies blast radius."
      },
      {
        "name": "RDP NLA disabled + open SMB share",
        "checkA": "RDP_NLA_DISABLED",
        "checkB": "OPEN_SMB_SHARE",
        "riskBoost": 2.0,
        "rationale": "Pre-auth RDP exposure combined with writable share creates both remote exec and persistence vectors."
      }
    ]
  },

  "output": {
    "formats": ["json", "html", "csv", "sentinel", "splunk"],
    "jsonPrettyPrint": true,
    "htmlIncludeEvidence": true,
    "htmlIncludeRemediation": true,
    "splunk": {
      "index": "zero_trust_audit",
      "sourcetype": "zta:finding",
      "host": "audit-workstation"
    },
    "sentinel": {
      "workspaceId": "",
      "tablePrefix": "ZTA",
      "logType": "ZeroTrustAuditFinding"
    }
  },

  "severity": {
    "baseScores": {
      "Critical":      9.0,
      "High":          7.0,
      "Medium":        5.0,
      "Low":           3.0,
      "Informational": 1.0
    },
    "maxScore": 10.0
  },

  "network": {
    "portProbeTimeoutMs": 3000,
    "maxParallelProbes": 50,
    "adminPorts": {
      "RDP":        3389,
      "SMB":        445,
      "WinRM":      5985,
      "WinRMHTTPS": 5986,
      "WMI":        135,
      "SSH":        22,
      "DCOM":       135
    },
    "crossSegmentAdminPorts": ["SMB", "WinRM", "WMI", "RDP"],
    "subnetClassificationMethod": "cidr"
  },

  "reporting": {
    "organizationName": "",
    "engagementName": "",
    "auditorName": "",
    "reportFooter": "Generated by ZeroTrustAuditor — read-only, non-destructive assessment."
  }
}
